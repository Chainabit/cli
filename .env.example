# Copy this file, fill in your values, and load it with:
#   chainabit --env-file .env.local <command>

# API base URL. Only needed if you're pointing at a non-default environment.
CHAINABIT_BASE_URL=https://api.chainabit.com/api/v1

# App origin used for browser-based auth flows (device approval, etc).
CHAINABIT_APP_BASE_URL=https://chainabit.com

# Pre-supply an access token or developer API key instead of running
# `chainabit auth login` interactively.
CHAINABIT_TOKEN=

# Default workspace to use when none is pinned via `chainabit workspace use`.
CHAINABIT_WORKSPACE_ID=
